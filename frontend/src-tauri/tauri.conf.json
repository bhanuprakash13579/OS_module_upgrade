{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "COPS",
  "version": "3.0.27",
  "identifier": "gov.in.customs.cops",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "COPS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "center": true,
        "visible": false,
        "backgroundColor": "#f8fafc"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' http://localhost:8000 http://127.0.0.1:8000 ws://localhost:8000; object-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/python-server"
    ],
    "resources": {},
    "windows": {
      "nsis": {
        "installerHooks": "./nsis/installer_hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libcairo2",
          "libpango-1.0-0",
          "libpangocairo-1.0-0",
          "libfontconfig1",
          "libgdk-pixbuf-2.0-0",
          "libharfbuzz0b"
        ]
      }
    },
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzQjc2QzU5QjU3MEQzOEEKUldTSzAzQzFXV3kzSTM1OGJ3QkpWbUI4djZieU1icjBxSjRDSHZhNmdra1c0UHYrVnoxZW9PUkgK",
      "endpoints": [
        "https://github.com/bhanuprakash13579/OS_module_upgrade/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
